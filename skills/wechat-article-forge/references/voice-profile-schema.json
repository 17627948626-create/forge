{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hermes.dev/schemas/wechat-article-writer/voice-profile.json",
  "title": "WeChatArticleWriter Voice Profile",
  "description": "Fallback summary and diagnostic voice artifact. Prefer voice-pack.json when available; use this profile for compatibility, observability, and last-resort guidance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "persona",
    "rhythm",
    "structure",
    "rhetoric",
    "vocabulary",
    "punctuation",
    "tone",
    "writing_prompt_injection"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "updated_at", "article_count", "version"],
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "article_count": { "type": "integer", "minimum": 0 },
        "version": { "type": "string" },
        "sample_titles": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 20
        }
      }
    },
    "persona": {
      "type": "object",
      "additionalProperties": false,
      "required": ["persona_mode", "reader_relationship", "opinion_strength"],
      "properties": {
        "persona_mode": {
          "type": "string",
          "enum": ["ai_native", "mixed", "human_like"]
        },
        "reader_relationship": {
          "type": "string",
          "enum": ["peer_to_peer", "friend_to_friend", "mentor_student", "expert_to_layperson"]
        },
        "opinion_strength": {
          "type": "string",
          "enum": ["mild_opinion", "clear_stance", "provocative"]
        },
        "humor_level": {
          "type": "string",
          "enum": ["none", "occasional_wit", "light_humor", "playful"]
        },
        "author_label": { "type": "string" },
        "boundary_notes": { "type": "string" }
      }
    },
    "rhythm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["avg_sentence_chars", "avg_paragraph_sentences", "short_sentence_ratio"],
      "properties": {
        "avg_sentence_chars": { "type": "number" },
        "avg_paragraph_sentences": { "type": "number" },
        "short_sentence_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "long_sentence_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "variation_score": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "structure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preferred_section_count", "uses_subheadings", "opening_style", "closing_style"],
      "properties": {
        "preferred_section_count": { "type": "integer", "minimum": 1, "maximum": 20 },
        "uses_subheadings": { "type": "boolean" },
        "uses_numbered_lists": { "type": "boolean" },
        "uses_bullet_lists": { "type": "boolean" },
        "uses_summary_box": { "type": "boolean" },
        "opening_style": { "type": "string" },
        "closing_style": { "type": "string" },
        "avg_word_count": { "type": "integer", "minimum": 0 }
      }
    },
    "rhetoric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dominant_devices"],
      "properties": {
        "dominant_devices": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "maxItems": 10
        },
        "uses_technical_deep_dives": { "type": "boolean" },
        "simplification_style": { "type": "string" },
        "self_reference_frequency": { "type": "string" }
      }
    },
    "vocabulary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formality_level", "english_loanword_style"],
      "properties": {
        "formality_level": { "type": "string" },
        "english_loanword_style": { "type": "string" },
        "signature_phrases": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 30
        },
        "avoid_phrases": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 30
        },
        "domain_focus": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 10
        }
      }
    },
    "punctuation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prefers_chinese_comma", "uses_em_dash", "uses_ellipsis"],
      "properties": {
        "prefers_chinese_comma": { "type": "boolean" },
        "uses_em_dash": { "type": "boolean" },
        "uses_ellipsis": { "type": "boolean" },
        "book_title_marks": { "type": "boolean" },
        "emoji_usage": { "type": "string" },
        "emoji_style": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 20
        }
      }
    },
    "tone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_tone", "secondary_tone", "reader_relationship", "opinion_strength"],
      "properties": {
        "primary_tone": { "type": "string" },
        "secondary_tone": { "type": "string" },
        "reader_relationship": { "type": "string" },
        "humor_level": { "type": "string" },
        "opinion_strength": { "type": "string" }
      }
    },
    "writing_prompt_injection": {
      "type": "string",
      "maxLength": 1200
    }
  }
}
